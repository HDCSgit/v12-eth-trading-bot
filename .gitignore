# V12 Trading Bot - Git Ignore

# 敏感配置文件
.env
config_local.py
secrets.json
*_secret*

# 数据库文件
*.db
*.db-journal
*.sqlite
*.sqlite3

# 日志文件
logs/
*.log

# 历史数据
*.csv
!example_data.csv

# Python缓存
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Jupyter Notebook
.ipynb_checkpoints

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# 系统文件
.DS_Store
Thumbs.db

# 备份文件
backup/
old/
temp/
tmp/

# 交易记录（可选，如果你想保密）
trades/
performance_reports/

# 但保留示例配置
!config.example.py
!README.md
